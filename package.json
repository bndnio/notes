{
  "scripts": {
    "deploy": "wrangler deploy",
    "dev": "wrangler dev",
    "test": "bun test --env-file .env.test test/integration.test.ts",
    "typecheck": "tsc --noEmit",
    "logs": "wrangler tail",
    "secret-encryption-key": "wrangler secret put ENCRYPTION_KEY",
    "secret-resend-key": "wrangler secret put RESEND_API_KEY",
    "secret-notion-client-secret": "wrangler secret put NOTION_CLIENT_SECRET",
    "gen-key": "bun run scripts/gen-key.ts",
    "add-user": "bun run scripts/add-user.ts",
    "generate-mcp-token": "bun run scripts/generate-mcp-token.ts",
    "add-email": "bun run scripts/add-email.ts",
    "rotate-notion-token": "bun run scripts/rotate-notion-token.ts",
    "clear-kv": "bun run scripts/clear-kv.ts",
    "bucket": "wrangler r2 bucket create bndnio-notes"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260511.1",
    "drizzle-kit": "^0.31.10",
    "wrangler": "^4.91.0"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "drizzle-orm": "^0.45.2"
  }
}
